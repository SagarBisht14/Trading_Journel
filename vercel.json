{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "https://trading-journel.onrender.com/api/$1" },
    { "src": "/uploads/(.*)", "dest": "https://trading-journel.onrender.com/uploads/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
